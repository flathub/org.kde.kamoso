{
    "id": "org.kde.kamoso",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kamoso",
    "rename-icon": "kamoso",
    "rename-appdata-file": "org.kde.kamoso.appdata.xml",
    "finish-args": [
        "--device=all",
        "--filesystem=xdg-pictures",
        "--filesystem=xdg-run/pipewire-0",
        "--filesystem=xdg-videos",
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--env=GST_PLUGIN_SYSTEM_PATH=/app/lib/gstreamer-1.0/:/usr/lib/gstreamer-1.0/"
    ],
    "cleanup": [
        "/share/doc"
    ],
    "modules": [
        {
            "name": "qml6glsink",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Dauto_features=disabled",
                "-Dugly=disabled",
                "-Dbad=disabled",
                "-Dgood=enabled",
                "-Dbase=enabled",
                "-Dqt6=enabled",
                "-Dgst-plugins-good:qt-wayland=enabled",
                "-Dgst-plugins-good:qt-x11=enabled",
                "-Dgst-plugins-base:gl=enabled",
                "-Dgst-plugins-base:x11=enabled",
                "-Dbuildtype=release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.freedesktop.org/gstreamer/gstreamer.git",
                    "tag": "1.26.10",
                    "commit": "bfdc62185e243d3633aa916187a566d03a587792",
                    "//": "Sync tag with the runtime-version gstreamer version",
                    "disable-submodules": true
                }
            ],
            "no-make-install": true,
            "post-install": [
                "install -Dt /app/lib/gstreamer-1.0/ subprojects/gst-plugins-good/ext/qt6/libgstqml6.so"
            ]
        },
        {
            "name": "kamoso",
            "config-opts": [
                "-DPATCHED_GSTREAMER=ON",
                "-DENABLE_TESTING=OFF"
            ],
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.3/src/kamoso-26.04.3.tar.xz",
                    "sha256": "11c361923764e5d33db524e204b45b83d1a84d223bcf605c2bd9c8b653e9cb66",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kamoso-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
