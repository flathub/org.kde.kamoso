{
    "id": "org.kde.kamoso",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.9",
    "sdk": "org.kde.Sdk",
    "command": "kamoso",
    "rename-icon": "kamoso",
    "finish-args": [
        "--device=all",
        "--filesystem=xdg-pictures",
        "--filesystem=xdg-run/pipewire-0",
        "--filesystem=xdg-videos",
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--env=GST_PLUGIN_SYSTEM_PATH=/app/lib/gstreamer-1.0/:/usr/lib/gstreamer-1.0/"
    ],
    "cleanup": [
        "*.a",
        "*.la",
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man"
    ],
    "modules": [
        {
            "name": "qml6glsink",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Dauto_features=disabled",
                "-Dugly=disabled",
                "-Dbad=disabled",
                "-Dgood=enabled",
                "-Dbase=enabled",
                "-Dqt6=enabled",
                "-Dgst-plugins-good:qt-wayland=enabled",
                "-Dgst-plugins-good:qt-x11=enabled",
                "-Dgst-plugins-base:gl=enabled",
                "-Dgst-plugins-base:x11=enabled",
                "--buildtype=release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.freedesktop.org/gstreamer/gstreamer.git",
                    "tag": "1.24.7",
                    "//": "Sync tag with the runtime-version gstreamer version",
                    "disable-submodules": true
                },
                {
                    "type": "patch",
                    "path": "0001-qml6glitem-qtitem-Allow-configuring-if-the-item-will.patch"
                }
            ],
            "no-make-install": true,
            "post-install": [
                "install -Dt /app/lib/gstreamer-1.0/ subprojects/gst-plugins-good/ext/qt6/libgstqml6.so"
            ]
        },
        {
            "name": "kamoso",
            "config-opts": [
                "-DPATCHED_GSTREAMER=ON",
                "-DENABLE_TESTING=OFF"
            ],
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kamoso-25.12.3.tar.xz",
                    "sha256": "781aa669979a0326994f90f71e8c2a391d89ec2e1fef066146773577fe8eb864",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kamoso-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
